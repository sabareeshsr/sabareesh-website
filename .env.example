# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# Neon PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
# IMPORTANT: Remove &channel_binding=require if present — it breaks the postgres driver
DATABASE_URI=postgresql://username:password@host/dbname?sslmode=require

# Payload CMS secret — any random 32+ character string
PAYLOAD_SECRET=your-32-character-random-secret-here

# Full URL of the site (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-site.netlify.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret for the /api/revalidate endpoint
# Any random string — must match what's set in Netlify env vars for production
REVALIDATION_SECRET=your-random-revalidation-secret
